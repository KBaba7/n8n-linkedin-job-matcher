# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Apify Configuration
APIFY_API_TOKEN=your_apify_api_token_here

# Groq Configuration (for resume parsing and job matching)
GROQ_API_KEY=your_groq_api_key_here

# Alternative LLM providers:
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# N8N Configuration
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http

# Optional: Database for storing user sessions
# DATABASE_URL=postgresql://user:password@localhost:5432/jobmatcher

# Optional: Redis for caching
# REDIS_URL=redis://localhost:6379

# LinkedIn Scraper Settings
MAX_JOBS_PER_SEARCH=20
SCRAPE_TIMEOUT_SECONDS=120

# Job Matching Settings
MIN_MATCH_SCORE=60
MAX_RESULTS_TO_RETURN=5
